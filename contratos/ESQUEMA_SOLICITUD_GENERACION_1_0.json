{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ghf_generation_request_1.0",
  "title": "Solicitud de generación P5-2",
  "type": "object",
  "required": [
    "schemaId",
    "contractVersion",
    "requestId",
    "createdAt",
    "sourceProject",
    "mode",
    "requestedActivityIds",
    "preserveAssignments",
    "enginePreference",
    "run",
    "policy",
    "projectSnapshot"
  ],
  "properties": {
    "schemaId": {
      "const": "ghf_generation_request_1.0"
    },
    "contractVersion": {
      "const": "1.0"
    },
    "requestId": {
      "type": "string",
      "minLength": 8
    },
    "createdAt": {
      "type": "string"
    },
    "sourceProject": {
      "type": "object"
    },
    "mode": {
      "enum": [
        "COMPLETE",
        "PARTIAL",
        "REPAIR"
      ]
    },
    "requestedActivityIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "preserveAssignments": {
      "const": true
    },
    "enginePreference": {
      "enum": [
        "AUTO",
        "HYBRID",
        "HEURISTIC"
      ]
    },
    "run": {
      "type": "object",
      "required": [
        "seed",
        "timeLimitMs"
      ]
    },
    "policy": {
      "type": "object",
      "required": [
        "directWriteAllowed",
        "requiresPreview",
        "requiresExplicitAcceptance",
        "targetMode"
      ],
      "properties": {
        "directWriteAllowed": {
          "const": false
        },
        "requiresPreview": {
          "const": true
        },
        "requiresExplicitAcceptance": {
          "const": true
        },
        "targetMode": {
          "const": "CREATE_SEPARATE_PREVIEW"
        }
      }
    },
    "projectSnapshot": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
