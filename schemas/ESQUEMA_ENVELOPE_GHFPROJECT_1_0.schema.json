{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horarios-Centro Demo.example/schemas/ghf-envelope-1.0.schema.json",
  "title": "Envelope del contenedor GHFProject 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "containerSchemaId",
    "containerVersion",
    "projectSchemaId",
    "projectSchemaVersion",
    "projectId",
    "createdAt",
    "savedAt",
    "application",
    "compatibility",
    "integrity",
    "privacy",
    "capabilities"
  ],
  "properties": {
    "containerSchemaId": {
      "const": "ghf_container_1.0"
    },
    "containerVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "projectSchemaId": {
      "const": "ghf_project_1.0"
    },
    "projectSchemaVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "projectId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "savedAt": {
      "type": "string",
      "format": "date-time"
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "phase"
      ],
      "properties": {
        "name": {
          "const": "Gestor de Horarios Escolares"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "phase": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimumReaderVersion",
        "maximumTestedReaderVersion",
        "migrationRequired"
      ],
      "properties": {
        "minimumReaderVersion": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "maximumTestedReaderVersion": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "migrationRequired": {
          "type": "boolean"
        },
        "sourceSchemaId": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "sourceSchemaVersion": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "manifestPath",
        "projectPath",
        "projectSha256"
      ],
      "properties": {
        "algorithm": {
          "const": "SHA-256"
        },
        "manifestPath": {
          "const": "manifest.sha256"
        },
        "projectPath": {
          "const": "project.json"
        },
        "projectSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "containsPersonalData",
        "intendedUse",
        "publicReleaseAllowed"
      ],
      "properties": {
        "containsPersonalData": {
          "type": "boolean"
        },
        "intendedUse": {
          "enum": [
            "PRIVATE_CENTER_PROJECT",
            "SYNTHETIC_TEST",
            "ANONYMIZED_EXAMPLE"
          ]
        },
        "publicReleaseAllowed": {
          "type": "boolean"
        },
        "classification": {
          "enum": [
            "PRIVATE",
            "INTERNAL",
            "SYNTHETIC",
            "PUBLIC"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "containsPersonalData": {
                "const": true
              }
            },
            "required": [
              "containsPersonalData"
            ]
          },
          "then": {
            "properties": {
              "publicReleaseAllowed": {
                "const": false
              }
            }
          }
        }
      ]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "optional"
      ],
      "properties": {
        "required": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        },
        "optional": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
          }
        }
      }
    }
  }
}
