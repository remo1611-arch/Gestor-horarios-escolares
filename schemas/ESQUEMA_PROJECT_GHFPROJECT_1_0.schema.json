{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horarios-Centro Demo.example/schemas/ghf-project-1.0.schema.json",
  "title": "Proyecto canónico GHFProject 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "identity",
    "center",
    "academicYear",
    "timeModel",
    "groups",
    "teachers",
    "subjects",
    "spaces",
    "teachingNeeds",
    "availability",
    "organizationalActivities",
    "constraints",
    "workflowPolicy",
    "solverConfiguration",
    "schedule",
    "metadata"
  ],
  "properties": {
    "schemaId": {
      "const": "ghf_project_1.0"
    },
    "schemaVersion": {
      "const": "1.0.0"
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "center": {
      "$ref": "#/$defs/center"
    },
    "academicYear": {
      "$ref": "#/$defs/academicYear"
    },
    "timeModel": {
      "$ref": "#/$defs/timeModel"
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/group"
      }
    },
    "teachers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/teacher"
      }
    },
    "subjects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subject"
      }
    },
    "spaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/space"
      }
    },
    "teachingNeeds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/teachingNeed"
      }
    },
    "availability": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/availability"
      }
    },
    "organizationalActivities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/organizationalActivity"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/constraint"
      }
    },
    "workflowPolicy": {
      "$ref": "#/$defs/workflowPolicy"
    },
    "solverConfiguration": {
      "$ref": "#/$defs/solverConfiguration"
    },
    "schedule": {
      "$ref": "#/$defs/schedule"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "extensionReferences": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^extensions/[A-Za-z0-9._/-]+$"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "nonEmpty": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectId",
        "title",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "projectId": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "$ref": "#/$defs/nonEmpty"
        },
        "status": {
          "enum": [
            "DRAFT",
            "PREVALIDATED",
            "CANDIDATE",
            "ACCEPTED",
            "ARCHIVED"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "contractId": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "description": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        }
      }
    },
    "center": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "centerId",
        "name",
        "centerType",
        "autonomousCommunity",
        "locality"
      ],
      "properties": {
        "centerId": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/nonEmpty"
        },
        "centerType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "autonomousCommunity": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "locality": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "responsibleRole": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        }
      }
    },
    "academicYear": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "type": "string",
          "pattern": "^20[0-9]{2}/20[0-9]{2}$"
        },
        "startDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "endDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    },
    "timeModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "days",
        "slots"
      ],
      "properties": {
        "days": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/day"
          }
        },
        "slots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/slot"
          }
        },
        "timezone": {
          "type": "string",
          "default": "Europe/Madrid"
        }
      }
    },
    "day": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "order"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "$ref": "#/$defs/nonEmpty"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "order",
        "kind",
        "start",
        "end"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "$ref": "#/$defs/nonEmpty"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "kind": {
          "enum": [
            "LECTIVE",
            "RECESS",
            "READING",
            "ENTRY",
            "EXIT",
            "NON_LECTIVE"
          ]
        },
        "start": {
          "type": "string",
          "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
        },
        "end": {
          "type": "string",
          "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
        },
        "countsPresence": {
          "type": "boolean"
        }
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "stage"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/nonEmpty"
        },
        "stage": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "level": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "section": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 32
        },
        "tutorTeacherId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "homeSpaceId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "active": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "teacher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "specialties",
        "employment",
        "workload",
        "roles"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "displayName": {
          "$ref": "#/$defs/nonEmpty"
        },
        "specialties": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "employment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "fraction",
            "itinerant"
          ],
          "properties": {
            "fraction": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 1
            },
            "itinerant": {
              "type": "boolean"
            },
            "weeklyPresenceSlots": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          }
        },
        "workload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weeklyLectiveLimit",
            "reductions"
          ],
          "properties": {
            "weeklyLectiveLimit": {
              "type": "number",
              "minimum": 0
            },
            "reductions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/reduction"
              }
            },
            "targetNonLectiveSlots": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            }
          }
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/role"
          }
        },
        "active": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "reduction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "weeklySlots"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "weeklySlots": {
          "type": "number",
          "minimum": 0
        },
        "notes": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "confirmed": {
          "type": "boolean"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "category"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/nonEmpty"
        },
        "category": {
          "enum": [
            "CURRICULAR",
            "TUTORSHIP",
            "SUPPORT",
            "ORGANIZATIONAL",
            "OTHER"
          ]
        },
        "code": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        }
      }
    },
    "space": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/nonEmpty"
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "capacity": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "active": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "teachingNeed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "groupId",
        "subjectId",
        "weeklySessions",
        "modality",
        "participantsRequired",
        "teacherRequirement",
        "spaceRequirement"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "groupId": {
          "$ref": "#/$defs/id"
        },
        "subjectId": {
          "$ref": "#/$defs/id"
        },
        "weeklySessions": {
          "type": "integer",
          "minimum": 1
        },
        "durationSlots": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "modality": {
          "enum": [
            "STANDARD",
            "SHARED_TEACHING",
            "SUPPORT",
            "SPLIT_GROUP"
          ]
        },
        "participantsRequired": {
          "type": "integer",
          "minimum": 1
        },
        "teacherRequirement": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "enum": [
                "ANY_QUALIFIED",
                "FIXED",
                "ALLOWED_SET"
              ]
            },
            "fixedTeacherIds": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/id"
              }
            },
            "allowedTeacherIds": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/id"
              }
            },
            "requiredSpecialties": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "spaceRequirement": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "enum": [
                "NONE",
                "HOME",
                "FIXED",
                "ALLOWED_SET"
              ]
            },
            "fixedSpaceId": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "allowedSpaceIds": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/id"
              }
            }
          }
        },
        "active": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "availability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "teacherId",
        "dayId",
        "slotId",
        "status"
      ],
      "properties": {
        "teacherId": {
          "$ref": "#/$defs/id"
        },
        "dayId": {
          "$ref": "#/$defs/id"
        },
        "slotId": {
          "$ref": "#/$defs/id"
        },
        "status": {
          "enum": [
            "AVAILABLE",
            "UNAVAILABLE",
            "PREFERRED",
            "AVOID"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        }
      }
    },
    "organizationalActivity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "label",
        "weeklyOccurrences",
        "participantTeacherIds"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "enum": [
            "MEETING",
            "RECESS_DUTY",
            "COORDINATION",
            "GUARD",
            "LEADERSHIP",
            "OTHER"
          ]
        },
        "label": {
          "$ref": "#/$defs/nonEmpty"
        },
        "weeklyOccurrences": {
          "type": "integer",
          "minimum": 1
        },
        "participantTeacherIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "participantGroupIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "allowedDayIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "allowedSlotIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "spaceId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "hardness",
        "scope",
        "active",
        "parameters"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "hardness": {
          "enum": [
            "HARD",
            "SOFT"
          ]
        },
        "scope": {
          "enum": [
            "CENTER",
            "GROUP",
            "TEACHER",
            "SUBJECT",
            "SPACE",
            "SESSION"
          ]
        },
        "weight": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "active": {
          "type": "boolean"
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "workflowPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directWriteAllowed",
        "previewRequired",
        "explicitAcceptanceRequired",
        "repairCreatesCopy",
        "blockHardConflicts",
        "importedDraftRequiresRevalidation",
        "allowWarningsInDraft",
        "automaticPlacement"
      ],
      "properties": {
        "directWriteAllowed": {
          "const": false
        },
        "previewRequired": {
          "const": true
        },
        "explicitAcceptanceRequired": {
          "const": true
        },
        "repairCreatesCopy": {
          "const": true
        },
        "blockHardConflicts": {
          "const": true
        },
        "importedDraftRequiresRevalidation": {
          "const": true
        },
        "allowWarningsInDraft": {
          "type": "boolean"
        },
        "automaticPlacement": {
          "const": false
        }
      }
    },
    "solverConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileId",
        "backendPreference",
        "seed",
        "timeLimitSeconds",
        "objectives",
        "prevalidation"
      ],
      "properties": {
        "profileId": {
          "$ref": "#/$defs/id"
        },
        "backendPreference": {
          "enum": [
            "HYBRID",
            "CP_SAT",
            "HEURISTIC",
            "AUTO"
          ]
        },
        "seed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        },
        "timeLimitSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        },
        "objectives": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objective"
          }
        },
        "prevalidation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "minimumPresenceMode",
            "weeklyLectiveSlotsExpected"
          ],
          "properties": {
            "minimumPresenceMode": {
              "enum": [
                "BLOCKING",
                "WARNING"
              ]
            },
            "weeklyLectiveSlotsExpected": {
              "type": "integer",
              "minimum": 1
            },
            "countReadingAsLective": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "weight",
        "enabled"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "weight": {
          "type": "number",
          "minimum": 0
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "sessions"
      ],
      "properties": {
        "status": {
          "enum": [
            "DRAFT",
            "PARTIAL",
            "CANDIDATE",
            "ACCEPTED"
          ]
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/session"
          }
        },
        "candidateId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "acceptedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "state",
        "teacherIds",
        "groupIds",
        "locked",
        "origin"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "state": {
          "enum": [
            "UNPLACED",
            "PLACED"
          ]
        },
        "sourceNeedId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "organizationalActivityId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "subjectId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "teacherIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "groupIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "placement": {
          "oneOf": [
            {
              "type": "null"
            },
            {
