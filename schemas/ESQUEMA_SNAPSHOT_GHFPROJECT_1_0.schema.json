{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://horarios-Centro Demo.example/schemas/ghf-snapshot-1.0.schema.json",
  "title": "Snapshot GHFProject 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "snapshotId",
    "projectId",
    "createdAt",
    "kind",
    "label",
    "projectSha256",
    "project"
  ],
  "properties": {
    "schemaId": {
      "const": "ghf_snapshot_1.0"
    },
    "schemaVersion": {
      "const": "1.0.0"
    },
    "snapshotId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "projectId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "kind": {
      "enum": [
        "AUTOMATIC",
        "MANUAL",
        "ACCEPTANCE",
        "MIGRATION",
        "RESTORE_SAFETY"
      ]
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "parentSnapshotId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "pinned": {
      "type": "boolean"
    },
    "projectSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "project": {
      "$ref": "https://horarios-Centro Demo.example/schemas/ghf-project-1.0.schema.json"
    }
  }
}
